# Default deny. This repository publishes the reusable paper-research skill,
# not the private research library.
*

# Root docs
!/.gitignore
!/README.md
!/SETUP.md
!/AGENTS.md
!/LICENSE

# Project-local Codex skill
!.agents/
!.agents/skills/
!.agents/skills/paper-research-team/
!.agents/skills/paper-research-team/SKILL.md
!.agents/skills/paper-research-team/config.yaml
!.agents/skills/paper-research-team/agents/
!.agents/skills/paper-research-team/agents/openai.yaml
!.agents/skills/paper-research-team/references/
!.agents/skills/paper-research-team/references/**

# Public Obsidian template and controlled tag registry
!papers/
!papers/obsidian/
!papers/obsidian/_templates/
!papers/obsidian/_templates/paper-note-template.md
!papers/obsidian/_indexes/
!papers/obsidian/_indexes/tag-registry.md
!papers/obsidian/_indexes/research-profile.example.md

# Local-only research-interest map
papers/obsidian/_indexes/research-profile.md
papers/obsidian/_indexes/domain-registry.md
papers/obsidian/_indexes/method-registry.md
papers/obsidian/_indexes/venue-registry.md
papers/obsidian/_indexes/keyword-registry.md

# Local environments and agent state
.agents/skills/paper-research-team/.venv/
.codex
.obsidian/
papers/.codex
papers/.claude/
papers/.obsidian/
papers/obsidian/.obsidian/

# Private research assets and generated outputs
papers/zotero/
papers/obsidian/notes/
papers/obsidian/pending-notes/
papers/state/
literature-reviews/

